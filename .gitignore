__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.env
.env.*
!.env.example

.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

dist/
build/
*.egg-info/
# PyInstaller generates *.spec at build root; we keep our hand-written
# specs under packaging/ so explicitly un-ignore them.
/*.spec
!packaging/*.spec

.vscode/
.idea/

# Per-run logs (verbose JSON / text)
logs/
*.log

# Captured failure screenshots + ad-hoc test outputs
debug_captures/
*.debug.png
.tmp/
